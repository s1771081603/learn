{
    "$schema": "./node_modules/oxfmt/configuration_schema.json",

    "printWidth": 150,
    "tabWidth": 4,
    "tabs": false,
    "semi": false,
    "singleQuote": true,
    "quoteProps": "as-needed",
    "bracketSpacing": true,
    "jsxBracketSameLine": true,
    "htmlWhitespaceSensitivity": "css",
    "trailingComma": "none",
    "useTabs": false,
    "jsxSingleQuote": true,
    "arrowParens": "always",
    "rangeStart": 0,
    "proseWrap": "always",
    "endOfLine": "lf"
}
