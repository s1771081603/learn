{
    "$schema": "./node_modules/oxlint/configuration_schema.json",
    "plugins": [
        "eslint",
        "typescript",
        "unicorn",
        "oxc",
        "vue"
    ],
    "env": {
        "browser": true,
        "node": true
    },
    "categories": {
        "correctness": "error",
        "perf": "warn",
        "suspicious": "warn"
    },
    "rules": {
        "vue/no-useless-assignment": "off",
        "no-console": "off",
        "no-debugger": "off",
        "typescript/no-explicit-any": "warn",
        "unicorn/prefer-module": "off"
    }
}
